@startuml core_backend_integration
skinparam monochrome true
skinparam shadowing false
skinparam linetype ortho

package "Внешние сервисы" {
    [GDELT API] as GDELT
    [Firebase Cloud Messaging] as FCM
}

package "Система мониторинга" {
    component [Fetcher (Сборщик)] as Fetcher
    component [Analyzer (Анализатор)] as Analyzer
    component [Core Backend (Ядро)] as Core
    
    database "PostgreSQL + PostGIS" {
        folder "Staging DB (Промежуточная)" as Staging
        folder "Core DB (Основная)" as CoreDB
    }
    
    queue "RabbitMQ (Брокер)" as RMQ
}

[React Frontend (Веб-интерфейс)] as Web

GDELT --> Fetcher : Данные CSV
Fetcher --> Staging : Сырое хранилище
Fetcher --> RMQ : Сигнал о новых записях
RMQ --> Analyzer : Задача на анализ
Analyzer --> Core : Обработанное событие (REST/gRPC)
Core --> CoreDB : Финальное хранилище
Core --> FCM : Отправка Push-уведомлений
FCM --> Web : Уведомление на клиенте
Web <--> Core : REST API / Геоданные

@enduml
